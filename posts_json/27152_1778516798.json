admin-ajax-58.jpg?fit=1100%2C1100&ssl=1&resize=1050%2C600 3x"}, "classes": []}, {"id": 34693, "url": "https://estreetshuffle.com/index.php/2022/05/30/roll-of-the-dice-mans-job/", "url_meta": {"origin": 27152, "position": 4}, "title": "Roll of the Dice: Man&#8217;s Job", "author": "Ken", "date": "May 30, 2022", "format": false, "excerpt": "This Stax/Volt homage (featuring Sam Moore himself) is an unjustly overlooked gem from Bruce's early 1990s era.", "rel": "", "context": "In &quot;Roll of the Dice&quot;", "block_context": {"text": "Roll of the Dice", "link": "https://estreetshuffle.com/index.php/category/roll-of-the-dice/"}, "img": {"alt_text": "", "src": "https://i0.wp.com/estreetshuffle.com/wp-content/uploads/2022/05/mansjob.jpg?fit=1200%2C696&ssl=1&resize=350%2C200", "width": 350, "height": 200, "srcset": "https://i0.wp.com/estreetshuffle.com/wp-content/uploads/2022/05/mansjob.jpg?fit=1200%2C696&ssl=1&resize=350%2C200 1x, https://i0.wp.com/estreetshuffle.com/wp-content/uploads/2022/05/mansjob.jpg?fit=1200%2C696&ssl=1&resize=525%2C300 1.5x, https://i0.wp.com/estreetshuffle.com/wp-content/uploads/2022/05/mansjob.jpg?fit=1200%2C696&ssl=1&resize=700%2C400 2x, https://i0.wp.com/estreetshuffle.com/wp-content/uploads/2022/05/mansjob.jpg?fit=1200%2C696&ssl=1&resize=1050%2C600 3x"}, "classes": []}, {"id": 22427, "url": "https://estreetshuffle.com/index.php/2020/11/17/cover-me-walking-the-dog/", "url_meta": {"origin": 27152, "position": 5}, "title": "Cover Me: Walking the Dog", "author": "Ken", "date": "November 17, 2020", "format": false, "excerpt": "The early E Street Band had a lot in common with the late Bruce Springsteen Band, and nowhere was that more apparent than in their cover of Rufus Thomas' \"Walking the Dog.\"", "rel": "", "context": "In &quot;Cover Me&quot;", "block_context": {"text": "Cover Me", "link": "https://estreetshuffle.com/index.php/category/cover-me/"}, "img": {"alt_text": "", "src": "https://i0.wp.com/estreetshuffle.com/wp-content/uploads/2020/11/