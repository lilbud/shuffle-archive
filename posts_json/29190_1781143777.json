 "href": "https://estreetshuffle.com/index.php/wp-json/wp/v2/comments?post=29190"}], "version-history": [{"count": 7, "href": "https://estreetshuffle.com/index.php/wp-json/wp/v2/posts/29190/revisions"}], "predecessor-version": [{"id": 69873, "href": "https://estreetshuffle.com/index.php/wp-json/wp/v2/posts/29190/revisions/69873"}], "wp:featuredmedia": [{"embeddable": true, "href": "https://estreetshuffle.com/index.php/wp-json/wp/v2/media/29244"}], "wp:attachment": [{"href": "https://estreetshuffle.com/index.php/wp-json/wp/v2/media?parent=29190"}], "wp:term": [{"taxonomy": "category", "embeddable": true, "href": "https://estreetshuffle.com/index.php/wp-json/wp/v2/categories?post=29190"}, {"taxonomy": "post_tag", "embeddable": true, "href": "https://estreetshuffle.com/index.php/wp-json/wp/v2/tags?post=29190"}], "curies": [{"name": "wp", "href": "https://api.w.org/{rel}", "templated": true}]}}