 {"alt_text": "", "src": "https://i0.wp.com/estreetshuffle.com/wp-content/uploads/2020/09/borderline.jpg?fit=1200%2C795&ssl=1&resize=350%2C200", "width": 350, "height": 200, "srcset": "https://i0.wp.com/estreetshuffle.com/wp-content/uploads/2020/09/borderline.jpg?fit=1200%2C795&ssl=1&resize=350%2C200 1x, https://i0.wp.com/estreetshuffle.com/wp-content/uploads/2020/09/borderline.jpg?fit=1200%2C795&ssl=1&resize=525%2C300 1.5x, https://i0.wp.com/estreetshuffle.com/wp-content/uploads/2020/09/borderline.jpg?fit=1200%2C795&ssl=1&resize=700%2C400 2x, https://i0.wp.com/estreetshuffle.com/wp-content/uploads/2020/09/borderline.jpg?fit=1200%2C795&ssl=1&resize=1050%2C600 3x"}, "classes": []}, {"id": 62388, "url": "https://estreetshuffle.com/index.php/2025/11/19/kingdom-of-days-november-19-2/", "url_meta": {"origin": 31943, "position": 1}, "title": "Kingdom of Days: November 19", "author": "Ken", "date": "November 19, 2025", "format": false, "excerpt": "On this significant date: Bruce pays tribute to Frank Sinatra on his 80th birthday, the Blood Brothers EP is released, and Danny Federici plays his final full show. Much more inside.", "rel": "", "context": "In &quot;Kingdom of Days&quot;", "block_context": {"text": "Kingdom of Days", "link": "https://estreetshuffle.com/index.php/category/kingdom-of-days/"}, "img": {"alt_text": "", "src": "https://i0.wp.com/estreetshuffle.com/wp-content/uploads/2019/11/bloodbrothers.png?fit=600%2C600&ssl=1&resize=350%2C200", "width": 350, "height": 200, "srcset": "https://i0.wp.com/estreetshuffle.com/wp-content/uploads/2019/11/bloodbrothers.png?fit=600%2C600&ssl=1&resize=350%2C200 1x, https://i0.wp.com/estreetshuffle.com/wp-content/uploads/2019/11/bloodbrothers.png?fit=600%2C600&ssl=1&resize=525%2C300 1.5x"}, "classes": []}, {"id": 43459, "url": "https://estreetshuffle.com/index.php/1995/01/01/album-companion-the-ghost-of-tom-joad/", "url_meta": {"origin": 31943, "position": 2}, "title": "Introduction", "author": "Ken", "date": "January 1, 1995", "format": false, "excerpt": "Bruce Springsteen's eleventh studio album is one of his best-sounding and most thematically cohesive. It wears its influences on its sleeves, and we'll explore them inside.", "rel": "", "context": "In &quot;Joad&quot;", "block_context": {"text": "Joad", "link": "https://estreetshuffle.com/index.php/category/joad/"}, "img": {"alt_text": "", "src": "https://i0.wp.com/estreetshuffle.com/wp-content/uploads/2019/11/tomjoad.jpg?fit=1200%2C1200&ssl=1&resize=350%2C200", "width": 350, "height": 200, "srcset": "https://i0.wp.com/estreetshuffle.com/wp-content/uploads/2019/11/tomjoad.jpg?fit=1200%2C1200&ssl=1&resize=350%2C200 1x, https://i0.wp.com/estreetshuffle.com/wp-content/uploads/2019/11/tomjoad.jpg?fit=1200%2C1200&ssl=1&resize=525%2C300 1.5x, https://i0.wp.com/estreetshuffle.com/wp-content/uploads/2019/11/tomjoad.jpg?fit=1200%2C1200&ssl=1&resize=700%2C400 2x, https://i0.wp.com/estreetshuffle.com/wp-content/uploads/2019/11/tomjoad.jpg?fit=1200%2C1200&ssl=1&resize=1050%2C600 3x"}, "classes": []}, {"id": 3401, "url": "https://estreetshuffle.com/index.php/2018/07/27/cover-me-gary-u-s-bonds-your-love/", "url_meta": {"origin": 31943, "position": 3}, "title": "RotD/Cover Me, Gary U.S. Bonds: Your Love", "author": "Ken", "date": "July 27, 2018", "format": false, "excerpt": "One of many great songs Bruce gave away, \"Your Love\" is the missing link in a story that begins with \"Little White Lies\" and ends with \"My Love Will Not Let You Down.\"", "rel": "", "context": "In &quot;Cover Me&quot;", "block_context": {"text": "Cover Me", "link": "https://estreetshuffle.com/index.php/category/cover-me/"}, "img": {"alt_text": "", "src": "https://i0.wp.com/estreetshuffle.com/wp-content/uploads/2018/07/dedication.jpg?fit=597%2C600&ssl=1&resize=350%2C200", "width": 350, "height": 200, "srcset": "https://i0.wp.com/estreetshuffle.com/wp-content/uploads/2018/07/dedication.jpg?fit=597%2C600&ssl=1&resize=350%2C200 1x, https://i0.wp.com/estreetshuffle.com/wp-content/uploads/2018/07/dedication.jpg?fit=597%2C600&ssl=1&resize=525%2C300 1.5x"}, "classes": []}, {"id": 12166, "url": "https://estreetshuffle.com/index.php/2019/08/14/cover-me-tori-amos-im-on-fire/", "url_meta": {"origin": 31943, "position": 4}, "title": "Cover Me, Tori Amos: I&#8217;m on Fire", "author": "Ken", "date": "August 14, 2019", "format": false, "excerpt": "It\u2019s a crossover! Listen in on my visit to \"Drive All Night,\" a Tori Amos podcast, in a special Tori-on-Bruce episode.", "rel": "", "context": "In &quot;Cover Me&quot;", "block_context": {"text": "Cover Me", "link": "https://estreetshuffle.com/index.php/category/cover-me/"}, "img": {"alt_text": "", "src": "https://i0.wp.com/estreetshuffle.com/wp-content/uploads/2019/08/TORI_AMOS_IMONFIRE-75771.jpg?fit=500%2C492&ssl=1&resize=350%2C200", "width": 350, "height": 200}, "classes": []}, {"id": 61368, "url": "https://estreetshuffle.com/index.php/2025/11/16/kingdom-of-days-november-16-2/", "url_meta": {"origin": 31943, "position": 5}, "title": "Kingdom of Days: November 16", "author": "Ken", "date": "November 16, 2025", "format": false, "excerpt": "Bruce debuts \"Sugarland,\" plays the first of two amazing Christic shows, and releases The Promise: The Darkness on the Edge of Town Story on this remarkable date. Lots more highlights inside.", "rel": "", "context": "In &quot;Kingdom of Days&quot;", "block_context": {"text": "Kingdom of Days", "link": "https://estreetshuffle.com/index.php/category/kingdom-of-days/"}, "img": {"alt_text": "", "src": "https://i0.wp.com/estreetshuffle.com/wp-content/uploads/2020/10/promise.jpg?fit=1186%2C1200&ssl=1&resize=350%2C200", "width": 350, "height": 200, "srcset": "https://i0.wp.com/estreetshuffle.com/wp-content/uploads/2020/10/promise.jpg?fit=1186%2C1200&ssl=1&resize=350%2C200 1x, https://i0.wp.com/estreetshuffle.com/wp-content/uploads/2020/10/promise.jpg?fit=1186%2C1200&ssl=1&resize=525%2C300 1.5x, https://i0.wp.com/estreetshuffle.com/wp-content/uploads/2020/10/promise.jpg?fit=1186%2C1200&ssl=1&resize=700%2C400 2x, https://i0.wp.com/estreetshuffle.com/wp-content/uploads/2020/10/promise.jpg?fit=1186%2C1200&ssl=1&resize=1050%2C600 3x"}, "classes": []}], "_links": {"self": [{"href": "https://estreetshuffle.com/index.php/wp-json/wp/v2/posts/31943", "targetHints": {"allow": ["GET"]}}], "collection": [{"href": "https://estreetshuffle.com/index.php/wp-json/wp/v2/posts"}], "about": [{"href": "https://estreetshuffle.com/index.php/wp-json/wp/v2/types/post"}], "author": [{"embeddable": true, "href": "https://estreetshuffle.com/index.php/wp-json/wp/v2/users/1"}], "replies": [{"embeddable": true, "href": "https://estreetshuffle.com/index.php/wp-json/wp/v2/comments?post=31943"}], "version-history": [{"count": 5, "href": "https://estreetshuffle.com/index.php/wp-json/wp/v2/posts/31943/revisions"}], "predecessor-version": [{"id": 69871, "href": "https://estreetshuffle.com/index.php/wp-json/wp/v2/posts/31943/revisions/69871"}], "wp:featuredmedia": [{"embeddable": true, "href": "https://estreetshuffle.com/index.php/wp-json/wp/v2/media/69869"}], "wp:attachment": [{"href": "https://estreetshuffle.com/index.php/wp-json/wp/v2/media?parent=31943"}], "wp:term": [{"taxonomy": "category", "embeddable": true, "href": "https://estreetshuffle.com/index.php/wp-json/wp/v2/categories?post=31943"}, {"taxonomy": "post_tag", "embeddable": true, "href": "https://estreetshuffle.com/index.php/wp-json/wp/v2/tags?post=31943"}], "curies": [{"name": "wp", "href": "https://api.w.org/{rel}", "templated": true}]}}