s/"}, "img": {"alt_text": "", "src": "https://i0.wp.com/estreetshuffle.com/wp-content/uploads/2022/04/esbhof-scaled.jpg?fit=1200%2C704&ssl=1&resize=350%2C200", "width": 350, "height": 200, "srcset": "https://i0.wp.com/estreetshuffle.com/wp-content/uploads/2022/04/esbhof-scaled.jpg?fit=1200%2C704&ssl=1&resize=350%2C200 1x, https://i0.wp.com/estreetshuffle.com/wp-content/uploads/2022/04/esbhof-scaled.jpg?fit=1200%2C704&ssl=1&resize=525%2C300 1.5x, https://i0.wp.com/estreetshuffle.com/wp-content/uploads/2022/04/esbhof-scaled.jpg?fit=1200%2C704&ssl=1&resize=700%2C400 2x, https://i0.wp.com/estreetshuffle.com/wp-content/uploads/2022/04/esbhof-scaled.jpg?fit=1200%2C704&ssl=1&resize=1050%2C600 3x"}, "classes": []}, {"id": 57929, "url": "https://estreetshuffle.com/index.php/2025/08/09/kingdom-of-days-august-9-2/", "url_meta": {"origin": 57927, "position": 4}, "title": "August 9", "author": "Ken", "date": "August 9, 2025", "format": false, "excerpt": "Bruce stuns locals in Montana when he jams with a restaurant house band, and shocks fans worldwide when Springsteen on Broadway is officially confirmed. Plus: Joe Grushecky catches his first Bruce concert, the Springsteen/Appel lawsuit gets underway, and Bruce plays his legendary Darkness Show at The Agora.", "rel": "", "context": "In &quot;Kingdom of Days&quot;", "block_context": {"text": "Kingdom of Days", "link": "https://estreetshuffle.com/index.php/category/kingdom-of-days/"}, "img": {"alt_text": "", "src": "https://i0.wp.com/estreetshuffle.com/wp-content/uploads/2019/08/01-Summertime-Blues-mp3-image.jpg?fit=1200%2C1200&ssl=1&resize=350%2C200", "width": 350, "height": 200, "srcset": "https://i0.wp.com/estreetshuffle.com/wp-content/uploads/2019/08/01-Summertime-Blues-mp3-image.jpg?fit=1200%2C1200&ssl=1&resize=350%2C200 1x, https://i0.wp.com/estreetshuffle.com/wp-content/uploads/2019/08/01-Summertime-Blues-mp3-image.jpg?fit=1200%2C1200&ssl=1&resize=525%2C300 1.5x, https://i0.wp.com/estreetshuffle.com/wp-content/uploads/2019/08/01-Summertime-Blues-mp3-image.jpg?fit=1200%2C1200&ssl=1&resize=700%2C400 2x, https://i0.wp.com/estreetshuffle.com/wp-content/uploads/2019/08/01-Summertime-Blues-mp3-image.jpg?fit=1200%2C1200&ssl=1&resize=1050%2C600 3x"}, "classes": []}, {"id": 57515, "url": "https://estreetshuffle.com/index.php/2025/06/29/kingdom-of-days-june-29-2/", "url_meta": {"origin": 57927, "position": 5}, "title": "June 29", "author": "Ken", "date": "June 29, 2025", "format": false, "excerpt": "A big, big day for Bruce: He sees his first ever rock concert, kicks off his biggest ever tour, films his most popular video, and debuts Nils and Patti as members of the E Street Band. Whew! There's a lot more inside, too.", "rel": "", "context": "In &quot;Kingdom of Days&quot;", "block_context": {"text": "Kingdom of Days", "link": "https://estreetshuffle.com/index.php/category/kingdom-of-days/"}, "img": {"alt_text": "", "src": "https://i0.wp.com/estreetshuffle.com/wp-content/uploads/2025/06/june-29th-2024-nijmegen-ne-bruce-springsteen-and-the-e-street-band-review.jpg?fit=1200%2C1200&ssl=1&resize=350%2C200", "width": 350, "height": 200, "srcset": "https://i0.wp.com/estreetshuffle.com/wp-content/uploads/2025/06/june-29th-2024-nijmegen-ne-bruce-springsteen-and-the-e-street-band-review.jpg?fit=1200%2C1200&ssl=1&resize=350%2C200 1x, https://i0.wp.com/estreetshuffle.com/wp-content/uploads/2025/06/june-29th-2024-nijmegen-ne-bruce-springsteen-and-the-e-street-band-review.jpg?fit=1200%2C1200&ssl=1&resize=525%2C300 1.5x, https://i0.wp.com/estreetshuffle.com/wp-content/uploads/2025/06/june-29th-2024-nijmegen-ne-bruce-springsteen-and-the-e-street-band-review.jpg?fit=1200%2C1200&ssl=1&resize=700%2C400 2x, https://i0.wp.com/estreetshuffle.com/wp-content/uploads/2025/06/june-29th-2024-nijmegen-ne-bruce-springsteen-and-the-e-street-band-review.jpg?fit=1200%2C1200&ssl=1&resize=1050%2C600 3x"}, "classes": []}], "_links": {"self": [{"href": "https://estreetshuffle.com/index.php/wp-json/wp/v2/posts/57927", "targetHints