%2C793&ssl=1&resize=525%2C300 1.5x, https://i0.wp.com/estreetshuffle.com/wp-content/uploads/2019/08/480699073_1161838361960903_8279953581274662997_n.jpg?fit=800%2C793&ssl=1&resize=700%2C400 2x"}, "classes": []}, {"id": 59734, "url": "https://estreetshuffle.com/index.php/2025/09/29/kingdom-of-days-september-29-2/", "url_meta": {"origin": 235, "position": 4}, "title": "September 29", "author": "Ken", "date": "September 29, 2025", "format": false, "excerpt": "Bruce plays with Pete Seeger for the first time, holds a rehearsal show for the Magic Tour, and gives a Philly schoolboy a great absence note.", "rel": "", "context": "In &quot;Kingdom of Days&quot;", "block_context": {"text": "Kingdom of Days", "link": "https://estreetshuffle.com/index.php/category/kingdom-of-days/"}, "img": {"alt_text": "", "src": "https://i0.wp.com/estreetshuffle.com/wp-content/uploads/2025/09/admin-ajax-93.jpg?fit=1200%2C1076&ssl=1&resize=350%2C200", "width": 350, "height": 200, "srcset": "https://i0.wp.com/estreetshuffle.com/wp-content/uploads/2025/09/admin-ajax-93.jpg?fit=1200%2C1076&ssl=1&resize=350%2C200 1x, https://i0.wp.com/estreetshuffle.com/wp-content/uploads/2025/09/admin-ajax-93.jpg?fit=1200%2C1076&ssl=1&resize=525%2C300 1.5x, https://i0.wp.com/estreetshuffle.com/wp-content/uploads/2025/09/admin-ajax-93.jpg?fit=1200%2C1076&ssl=1&resize=700%2C400 2x, https://i0.wp.com/estreetshuffle.com/wp-content/uploads/2025/09/admin-ajax-93.jpg?fit=1200%2C1076&ssl=1&resize=1050%2C600 3x"}, "classes": []}, {"id": 15412, "url": "https://estreetshuffle.com/index.php/1987/04/01/matr-bruce-springsteen-and-gary-u-s-bonds-soul-deep/", "url_meta": {"origin": 235, "position": 5}, "title": "Soul Deep", "author": "Ken", "date": "April 1, 1987", "format": false, "excerpt": "Did he or didn't he? Bruce and Gary U.S. Bonds played \"Soul Deep\" on stage together in 2003, but the jury's out on whether that was really Bruce's first time singing the 1969 blue-eyed soul classic with Gary.", "rel": "", "context": "In &