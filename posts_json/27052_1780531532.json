25%2C300 1.5x, https://i0.wp.com/estreetshuffle.com/wp-content/uploads/2019/08/19880902_front.jpg?fit=1200%2C1200&ssl=1&resize=700%2C400 2x, https://i0.wp.com/estreetshuffle.com/wp-content/uploads/2019/08/19880902_front.jpg?fit=1200%2C1200&ssl=1&resize=1050%2C600 3x"}, "classes": []}, {"id": 17124, "url": "https://estreetshuffle.com/index.php/2020/04/18/cover-me-shake-rattle-and-roll/", "url_meta": {"origin": 27052, "position": 2}, "title": "Cover Me: Shake, Rattle and Roll", "author": "Ken", "date": "April 18, 2020", "format": false, "excerpt": "A rusty E Street Band lumbered through their first attempt at Big Joe Turner's rock and roll standard, but they more than made up for it 18 years later.", "rel": "", "context": "In &quot;Cover Me&quot;", "block_context": {"text": "Cover Me", "link": "https://estreetshuffle.com/index.php/category/cover-me/"}, "img": {"alt_text": "", "src": "https://i0.wp.com/estreetshuffle.com/wp-content/uploads/2020/04/shakerattle.jpg?fit=466%2C466&ssl=1&resize=350%2C200", "width": 350, "height": 200}, "classes": []}, {"id": 17542, "url": "https://estreetshuffle.com/index.php/1988/09/22/matr-bruce-springsteen-and-jerry-lee-lewis-whole-lotta-shakin-goin-on/", "url_meta": {"origin": 27052, "position": 3}, "title": "Whole Lotta Shakin&#8217; Goin&#8217; On", "author": "Ken", "date": "September 22, 1988", "format": false, "excerpt": "Twice in the mid-nineties, Bruce and Jerry Lee Lewis tackled Lewis' first great hit together, and both times they fell short. Let's take a look and listen to find out why.", "rel": "", "context": "In &quot;Cover Me&quot;", "block_context": {"text": "Cover Me", "link": "https://estreetshuffle.com/index.php/category/cover-me/"}, "img": {"alt_text": "", "src": "https://i0.wp.com/estreetshuffle.com/wp-content/uploads/2020/05/admin-ajax-41.jpg?fit=1000%2C1000&ssl=1&resize=350%2C200", "width": 350, "height": 200, "srcset": "https://i0.wp.com/estreetshuffle.com/wp-content/uploads/2020/05/admin-ajax-41.jpg?fit=1000%2C1000&ssl=1&resize=350%2C200 1x, https://i0.wp.com/estreetshuffle.com/wp-content/uploads/2020/05/admin-ajax-41.jpg?fit=1000%2C1000&ssl=1&resize=525%2C300 1.5x, https://i0.wp.com/estreetshuffle.com/wp-content/uploads/2020/05/admin-ajax-41.jpg?fit=1000%2C1000&ssl=1&resize=700%2C400 2x"}, "classes": []}, {"id": 11794, "url": "https://estreetshuffle.com/index.php/2019/08/08/cover-me-roll-over-beethoven/", "url_meta": {"origin": 27052, "position": 4}, "title": "Cover Me: Roll Over Beethoven", "author": "Ken", "date": "August 8, 2019", "format": false, "excerpt": "Bruce covered it several times over the years, as far back as 1971--but it took until 2009 before a taper could capture Bruce covering Chuck Berry's seminal classic, \"Roll Over Beethoven.\"", "rel": "", "context": "In &quot;Cover Me&quot;", "block_context": {"text": "Cover Me", "link": "https://estreetshuffle.com/index.php/category/cover-me/"}, "img": {"alt_text": "", "src": "https://i0.wp.com/estreetshuffle.com/wp-content/uploads/2019/08/rollover.jpg?fit=1009%2C1024&ssl=1&resize=350%2C200", "width": 350, "height": 200, "srcset": "https://i0.wp.com/estreetshuffle.com/wp-content/uploads/2019/08/rollover.jpg?fit=1009%2C1024&ssl=1&resize=350%2C200 1x, https://i0.wp.com/estreetshuffle.com/wp-content/uploads/2019/08/rollover.jpg?fit=1009%2C1024&ssl=1&resize=525%2C300 1.5x, https://i0.wp.com/estreetshuffle.com/wp-content/uploads/2019/08/rollover.jpg?fit=1009%2C1024&ssl=1&resize=700%2C400 2x"}, "classes": []}, {"id": 36883, "url": "https://estreetshuffle.com/index.php/1988/08/31/matr-bruce-springsteen-jerry-lee-lewis-and-joe-ely-great-balls-of-fire/", "url_meta": {"origin": 27052, "position": 5}, "title": "Great Balls of Fire", "author": "Ken", "date": "August 31, 1988", "format": false, "excerpt": "Bruce took two cracks at performing Jerry Lee Lewis' signature song with The Killer, but it took a guest appearance by the Jerry Lee-influenced Joe Ely to get it right.", "rel": "", "context": "In &quot;Cover Me&quot;", "block_c