: block;\"><iframe loading=\"lazy\" class=\"youtube-player\" width=\"758\" height=\"427\" src=\"https://www.youtube.com/embed/q9oSaZz_ieg?version=3&#038;rel=1&#038;showsearch=0&#038;showinfo=1&#038;iv_load_policy=1&#038;fs=1&#038;hl=en-US&#038;autohide=2&#038;wmode=transparent\" allowfullscreen=\"true\" style=\"border:0;\" sandbox=\"allow-scripts allow-same-origin allow-popups allow-presentation allow-popups-to-escape-sandbox\"></iframe></span></div>\n<audio class=\"wp-audio-shortcode\" id=\"audio-61212-1\" preload=\"none\" style=\"width: 100%;\" controls=\"controls\"><source type=\"audio/mpeg\" src=\"https://estreetshuffle.com/wp-content/uploads/2022/10/1995-10-24__Merged.mp3?_=1\" /><a href=\"https://estreetshuffle.com/wp-content/uploads/2022/10/1995-10-24__Merged.mp3\">https://estreetshuffle.com/wp-content/uploads/2022/10/1995-10-24__Merged.mp3</a></audio>\n<p><strong><img data-recalc-dims=\"1\" loading=\"lazy\" decoding=\"async\" data-attachment-id=\"22022\" data-permalink=\"https://estreetshuffle.com/1995-10-24/\" data-orig-file=\"https://i0.wp.com/estreetshuffle.com/wp-content/uploads/2020/10/1995-10-24.png?fit=1659%2C1265&amp;ssl=1\" data-orig-size=\"1659,1265\" data-comments-opened=\"1\" data-image-meta=\"{&quot;aperture&quot;:&quot;0&quot;,&quot;credit&quot;:&quot;&quot;,&quot;camera&quot;:&quot;&quot;,&quot;caption&quot;:&quot;&quot;,&quot;created_timestamp&quot;:&quot;0&quot;,&quot;copyright&quot;:&quot;&quot;,&quot;focal_length&quot;:&quot;0&quot;,&quot;iso&quot;:&quot;0&quot;,&quot;shutter_speed&quot;:&quot;0&quot;,&quot;title&quot;:&quot;&quot;,&quot;orientation&quot;:&quot;0&quot;}\" data-image-title=\"1995-10-24\" data-image-description=\"\" data-image-caption=\"\" data-large-file=\"https://i0.wp.com/estreetshuffle.com/wp-content/uploads/2020/10/1995-10-24.png?fit=758%2C578&amp;ssl=1\" class=\"alignnone wp-image-22022 size-full\" src=\"https://i0.wp.com/estreetshuffle.com/wp-content/uploads/2020/10/1995-10-24.png?resize=758%2C578&#038;ssl=1\" alt=\"\