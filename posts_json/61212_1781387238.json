.jpg?fit=1200%2C1200&ssl=1&resize=350%2C200 1x, https://i0.wp.com/estreetshuffle.com/wp-content/uploads/2025/08/admin-ajax-72.jpg?fit=1200%2C1200&ssl=1&resize=525%2C300 1.5x, https://i0.wp.com/estreetshuffle.com/wp-content/uploads/2025/08/admin-ajax-72.jpg?fit=1200%2C1200&ssl=1&resize=700%2C400 2x, https://i0.wp.com/estreetshuffle.com/wp-content/uploads/2025/08/admin-ajax-72.jpg?fit=1200%2C1200&ssl=1&resize=1050%2C600 3x"}, "classes": []}, {"id": 61150, "url": "https://estreetshuffle.com/index.php/2025/10/17/kingdom-of-days-october-17-2/", "url_meta": {"origin": 61212, "position": 3}, "title": "October 17", "author": "Ken", "date": "October 17, 2025", "format": false, "excerpt": "On this date in Springsteen history: A live radio broadcast from The Roxy, guest appearances with The Knack and U2, and more.", "rel": "", "context": "In &quot;Kingdom of Days&quot;", "block_context": {"text": "Kingdom of Days", "link": "https://estreetshuffle.com/index.php/category/kingdom-of-days/"}, "img": {"alt_text": "", "src": "https://i0.wp.com/estreetshuffle.com/wp-content/uploads/2021/10/american-babylon.jpg?fit=1200%2C675&ssl=1&resize=350%2C200", "width": 350, "height": 200, "srcset": "https://i0.wp.com/estreetshuffle.com/wp-content/uploads/2021/10/american-babylon.jpg?fit=1200%2C675&ssl=1&resize=350%2C200 1x, https://i0.wp.com/estreetshuffle.com/wp-content/uploads/2021/10/american-babylon.jpg?fit=1200%2C675&ssl=1&resize=525%2C300 1.5x, https://i0.wp.com/estreetshuffle.com/wp-content/uploads/2021/10/american-babylon.jpg?fit=1200%2C675&ssl=1&resize=700%2C400 2x, https://i0.wp.com/estreetshuffle.com/wp-content/uploads/2021/10/american-babylon.jpg?fit=1200%2C675&ssl=1&resize=1050%2C600 3x"}, "classes": []}, {"id": 62478, "url": "https://estreetshuffle.com/index.php/2025/11/29/kingdom-of-days-november-29-2/", "url_meta": {"origin": 61212, "position": 4}, "title": "Kingdom of Days: November 29", "author": "Ken", "date": "November 29, 2025", "format": false, "excerpt": "On this date: Br