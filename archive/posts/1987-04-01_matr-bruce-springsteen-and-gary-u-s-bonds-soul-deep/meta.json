-content/uploads/2022/04/lowlands.jpg?fit=1200%2C675&ssl=1&resize=350%2C200 1x, https://i0.wp.com/estreetshuffle.com/wp-content/uploads/2022/04/lowlands.jpg?fit=1200%2C675&ssl=1&resize=525%2C300 1.5x, https://i0.wp.com/estreetshuffle.com/wp-content/uploads/2022/04/lowlands.jpg?fit=1200%2C675&ssl=1&resize=700%2C400 2x, https://i0.wp.com/estreetshuffle.com/wp-content/uploads/2022/04/lowlands.jpg?fit=1200%2C675&ssl=1&resize=1050%2C600 3x"}, "classes": []}, {"id": 13915, "url": "https://estreetshuffle.com/index.php/1987/03/09/matr-little-steven-and-bruce-springsteen-can-i-get-a-witness/", "url_meta": {"origin": 15412, "position": 4}, "title": "Can I Get a Witness", "author": "Ken", "date": "March 9, 1987", "format": false, "excerpt": "One time only: Bruce and Little Steven team-up for an encore of Marvin Gaye's \"Can I Get a Witness\" at Steve's Soulfire record release event.", "rel": "", "context": "In &quot;Cover Me&quot;", "block_context": {"text": "Cover Me", "link": "https://estreetshuffle.com/index.php/category/cover-me/"}, "img": {"alt_text": "", "src": "https://i0.wp.com/estreetshuffle.com/wp-content/uploads/2019/11/admin-ajax-2026-06-09T133040.952.jpg?fit=1038%2C1050&ssl=1&resize=350%2C200", "width": 350, "height": 200, "srcset": "https://i0.wp.com/estreetshuffle.com/wp-content/uploads/2019/11/admin-ajax-2026-06-09T133040.952.jpg?fit=1038%2C1050&ssl=1&resize=350%2C200 1x, https://i0.wp.com/estreetshuffle.com/wp-content/uploads/2019/11/admin-ajax-2026-06-09T133040.952.jpg?fit=1038%2C1050&ssl=1&resize=525%2C300 1.5x, https://i0.wp.com/estreetshuffle.com/wp-content/uploads/2019/11/admin-ajax-2026-06-09T133040.952.jpg?fit=1038%2C1050&ssl=1&resize=700%2C400 2x"}, "classes": []}, {"id": 14361, "url": "https://estreetshuffle.com/index.php/2019/11/27/cover-me-scott-jacobs-dry-lightning/", "url_meta": {"origin": 15412, "position": 5}, "title": "Cover Me, Scott Jacobs: Dry Lightning", "author": "Ken", "date": "November 27, 2019", "format": false, "excerpt": "Canadian fol