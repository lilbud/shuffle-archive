ht": 200, "srcset": "https://i0.wp.com/estreetshuffle.com/wp-content/uploads/2020/06/hoochie.jpg?fit=1200%2C1200&ssl=1&resize=350%2C200 1x, https://i0.wp.com/estreetshuffle.com/wp-content/uploads/2020/06/hoochie.jpg?fit=1200%2C1200&ssl=1&resize=525%2C300 1.5x, https://i0.wp.com/estreetshuffle.com/wp-content/uploads/2020/06/hoochie.jpg?fit=1200%2C1200&ssl=1&resize=700%2C400 2x, https://i0.wp.com/estreetshuffle.com/wp-content/uploads/2020/06/hoochie.jpg?fit=1200%2C1200&ssl=1&resize=1050%2C600 3x"}, "classes": []}, {"id": 57873, "url": "https://estreetshuffle.com/index.php/2025/07/29/kingdom-of-days-july-29-2/", "url_meta": {"origin": 8490, "position": 5}, "title": "July 29", "author": "Ken", "date": "July 29, 2025", "format": false, "excerpt": "Happy birthday, Patti Scialfa, born on this date in 1953! Watch Bruce wish his wife a happy birthday by premiering \"Give the Girl a Kiss\" in her honor. More highlights inside.", "rel": "", "context": "In &quot;Kingdom of Days&quot;", "block_context": {"text": "Kingdom of Days", "link": "https://estreetshuffle.com/index.php/category/kingdom-of-days/"}, "img": {"alt_text": "", "src": "https://i0.wp.com/estreetshuffle.com/wp-content/uploads/2025/07/admin-ajax-52.jpg?fit=1200%2C1044&ssl=1&resize=350%2C200", "width": 350, "height": 200, "srcset": "https://i0.wp.com/estreetshuffle.com/wp-content/uploads/2025/07/admin-ajax-52.jpg?fit=1200%2C1044&ssl=1&resize=350%2C200 1x, https://i0.wp.com/estreetshuffle.com/wp-content/uploads/2025/07/admin-ajax-52.jpg?fit=1200%2C1044&ssl=1&resize=525%2C300 1.5x, https://i0.wp.com/estreetshuffle.com/wp-content/uploads/2025/07/admin-ajax-52.jpg?fit=1200%2C1044&ssl=1&resize=700%2C400 2x, https://i0.wp.com/estreetshuffle.com/wp-content/uploads/2025/07/admin-ajax-52.jpg?fit=1200%2C1044&ssl=1&resize=1050%2C600 3x"}, "classes": []}], "_links": {"self": [{"href": "https://estreetshuffle.com/index.php/wp-json/wp/v2/posts/8490", "targetHints": {"allow": ["GET"]}}], "collection": [{"href": "https://estreetshu