NLMxL._UF10001000_QL80_.jpg?fit=1000%2C1000&ssl=1&resize=700%2C400 2x"}, "classes": []}, {"id": 9731, "url": "https://estreetshuffle.com/index.php/1984/01/17/roll-of-the-dice-baby-im-so-cold/", "url_meta": {"origin": 68572, "position": 1}, "title": "Baby, I&#8217;m So Cold", "author": "Ken", "date": "January 17, 1984", "format": false, "excerpt": "The illegitimate child of \"Loose Ends\" and \"Follow That Dream\" still lives deep in the vault, but you can listen to an early demo of it inside.", "rel": "", "context": "In &quot;BITUSA&quot;", "block_context": {"text": "BITUSA", "link": "https://estreetshuffle.com/index.php/category/bitusa/"}, "img": {"alt_text": "", "src": "https://i0.wp.com/estreetshuffle.com/wp-content/uploads/2019/05/socold.jpg?fit=794%2C622&ssl=1&resize=350%2C200", "width": 350, "height": 200, "srcset": "https://i0.wp.com/estreetshuffle.com/wp-content/uploads/2019/05/socold.jpg?fit=794%2C622&ssl=1&resize=350%2C200 1x, https://i0.wp.com/estreetshuffle.com/wp-content/uploads/2019/05/socold.jpg?fit=794%2C622&ssl=1&resize=525%2C300 1.5x, https://i0.wp.com/estreetshuffle.com/wp-content/uploads/2019/05/socold.jpg?fit=794%2C622&ssl=1&resize=700%2C400 2x"}, "classes": []}, {"id": 24475, "url": "https://estreetshuffle.com/index.php/1984/01/17/roll-of-the-dice-bells-of-san-salvador/", "url_meta": {"origin": 68572, "position": 2}, "title": "Bells of San Salvador", "author": "Ken", "date": "January 17, 1984", "format": false, "excerpt": "New lyrics for a Creedence Clearwater Revival classic combine with tragic inspiration in El Salvador in this fascinating early home demo.", "rel": "", "context": "In &quot;BITUSA&quot;", "block_context": {"text": "BITUSA", "link": "https://estreetshuffle.com/index.php/category/bitusa/"}, "img": {"alt_text": "", "src": "https://i0.wp.com/estreetshuffle.com/wp-content/uploads/2021/02/admin-ajax-55.jpg?fit=992%2C970&ssl=1&resize=350%2C200", "width": 350, "height": 200, "srcset": "https://i0.wp.com/estreetshuffle.com/wp-content/u