uffle.com/wp-content/uploads/2020/09/playit.jpg?fit=1200%2C1200&ssl=1&resize=350%2C200 1x, https://i0.wp.com/estreetshuffle.com/wp-content/uploads/2020/09/playit.jpg?fit=1200%2C1200&ssl=1&resize=525%2C300 1.5x, https://i0.wp.com/estreetshuffle.com/wp-content/uploads/2020/09/playit.jpg?fit=1200%2C1200&ssl=1&resize=700%2C400 2x, https://i0.wp.com/estreetshuffle.com/wp-content/uploads/2020/09/playit.jpg?fit=1200%2C1200&ssl=1&resize=1050%2C600 3x"}, "classes": []}, {"id": 52381, "url": "https://estreetshuffle.com/index.php/2024/07/04/cover-me-turn-back-the-hands-of-time/", "url_meta": {"origin": 26261, "position": 1}, "title": "Cover Me: Turn Back the Hands of Time", "author": "Ken", "date": "July 4, 2024", "format": false, "excerpt": "One of the strongest tracks on the album and one of the few to receive a promotional push, we're still waiting for the proper concert debut for Bruce's cover of Tyrone Davis' 1970 classic.", "rel": "", "context": "In &quot;Cover Me&quot;", "block_context": {"text": "Cover Me", "link": "https://estreetshuffle.com/index.php/category/cover-me/"}, "img": {"alt_text": "", "src": "https://i0.wp.com/estreetshuffle.com/wp-content/uploads/2024/07/51SLlhhNGL._UF10001000_QL80_.jpg?fit=1000%2C984&ssl=1&resize=350%2C200", "width": 350, "height": 200, "srcset": "https://i0.wp.com/estreetshuffle.com/wp-content/uploads/2024/07/51SLlhhNGL._UF10001000_QL80_.jpg?fit=1000%2C984&ssl=1&resize=350%2C200 1x, https://i0.wp.com/estreetshuffle.com/wp-content/uploads/2024/07/51SLlhhNGL._UF10001000_QL80_.jpg?fit=1000%2C984&ssl=1&resize=525%2C300 1.5x, https://i0.wp.com/estreetshuffle.com/wp-content/uploads/2024/07/51SLlhhNGL._UF10001000_QL80_.jpg?fit=1000%2C984&ssl=1&resize=700%2C400 2x"}, "classes": []}, {"id": 51968, "url": "https://estreetshuffle.com/index.php/2024/06/16/cover-me-turn-on-your-love-light/", "url_meta": {"origin": 26261, "position": 2}, "title": "Cover Me: Turn On Your Love Light", "author": "Ken", "date": "June 16, 2024", "format": false, "excerpt"