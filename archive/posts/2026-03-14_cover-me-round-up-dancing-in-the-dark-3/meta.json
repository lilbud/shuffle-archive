09 is my favorite.", "rel": "", "context": "In &quot;Cover Me&quot;", "block_context": {"text": "Cover Me", "link": "https://estreetshuffle.com/index.php/category/cover-me/"}, "img": {"alt_text": "", "src": "https://i0.wp.com/estreetshuffle.com/wp-content/uploads/2018/02/kearney.jpg?fit=678%2C399&ssl=1&resize=350%2C200", "width": 350, "height": 200, "srcset": "https://i0.wp.com/estreetshuffle.com/wp-content/uploads/2018/02/kearney.jpg?fit=678%2C399&ssl=1&resize=350%2C200 1x, https://i0.wp.com/estreetshuffle.com/wp-content/uploads/2018/02/kearney.jpg?fit=678%2C399&ssl=1&resize=525%2C300 1.5x"}, "classes": []}, {"id": 1656, "url": "https://estreetshuffle.com/index.php/2018/06/05/cover-me-tina-turner-dancing-in-the-dark/", "url_meta": {"origin": 68336, "position": 3}, "title": "Cover Me, Tina Turner: Dancing in the Dark", "author": "Ken", "date": "June 5, 2018", "format": false, "excerpt": "Two superstars at the height of their popularity in 1985: Tina Turner covers Bruce's greatest hit.", "rel": "", "context": "In &quot;Cover Me&quot;", "block_context": {"text": "Cover Me", "link": "https://estreetshuffle.com/index.php/category/cover-me/"}, "img": {"alt_text": "", "src": "https://i0.wp.com/estreetshuffle.com/wp-content/uploads/2018/04/Tina-Turner-Live-in-Tokyo-1985-TSP-103-front-e1522904668626.jpg?fit=601%2C380&ssl=1&resize=350%2C200", "width": 350, "height": 200, "srcset": "https://i0.wp.com/estreetshuffle.com/wp-content/uploads/2018/04/Tina-Turner-Live-in-Tokyo-1985-TSP-103-front-e1522904668626.jpg?fit=601%2C380&ssl=1&resize=350%2C200 1x, https://i0.wp.com/estreetshuffle.com/wp-content/uploads/2018/04/Tina-Turner-Live-in-Tokyo-1985-TSP-103-front-e1522904668626.jpg?fit=601%2C380&ssl=1&resize=525%2C300 1.5x"}, "classes": []}, {"id": 2773, "url": "https://estreetshuffle.com/index.php/2018/06/29/cover-me-kermit-the-frog-dancing-in-the-dark/", "url_meta": {"origin": 68336, "position": 4}, "title": "Cover Me, Kermit the Frog: Dancing in the Dark", "author": "Ken", "date": "June 29, 2018", "format": false, "excerpt": "Celebrate the anniversary of Bruce's \"Dancing in the Dark\" video with this 1996 homage by the Muppets.", "rel": "", "context": "In &quot;Cover Me&quot;", "block_context": {"text": "Cover Me", "link": "https://estreetshuffle.com/index.php/category/cover-me/"}, "img": {"alt_text": "", "src": "https://i0.wp.com/img.youtube.com/vi/8mNyZVbSv5g/0.jpg?resize=350%2C200", "width": 350, "height": 200}, "classes": []}, {"id": 31272, "url": "https://estreetshuffle.com/index.php/2022/01/11/cover-me-round-up-dancing-in-the-dark-part-3/", "url_meta": {"origin": 68336, "position": 5}, "title": "Cover Me Round-Up: Dancing in the Dark (Part 3)", "author": "Ken", "date": "January 11, 2022", "format": false, "excerpt": "Six new takes on Bruce's most popular song\u2013each with its own unique spin.", "rel": "", "context": "In &quot;Cover Me&quot;", "block_context": {"text": "Cover Me", "link": "https://estreetshuffle.com/index.php/category/cover-me/"}, "img": {"alt_text": "", "src": "https://i0.wp.com/estreetshuffle.com/wp-content/uploads/2022/01/ruthmoody.jpg?fit=1200%2C675&ssl=1&resize=350%2C200", "width": 350, "height": 200, "srcset": "https://i0.wp.com/estreetshuffle.com/wp-content/uploads/2022/01/ruthmoody.jpg?fit=1200%2C675&ssl=1&resize=350%2C200 1x, https://i0.wp.com/estreetshuffle.com/wp-content/uploads/2022/01/ruthmoody.jpg?fit=1200%2C675&ssl=1&resize=525%2C300 1.5x, https://i0.wp.com/estreetshuffle.com/wp-content/uploads/2022/01/ruthmoody.jpg?fit=1200%2C675&ssl=1&resize=700%2C400 2x, https://i0.wp.com/estreetshuffle.com/wp-content/uploads/2022/01/ruthmoody.jpg?fit=1200%2C675&ssl=1&resize=1050%2C600 3x"}, "classes": []}], "_links": {"self": [{"href": "https://estreetshuffle.com/index.php/wp-json/wp/v2/posts/68336", "targetHints": {"allow": ["GET"]}}], "collection": [{"href": "https://estreetshuffle.com/index.php/wp-json/wp/v2/posts"}], "about": [{"href": "https://estreetshuffle.com/index.php/wp-json/wp/v2/types/post"}], "author": [{"embeddable": true, "href": "https://estreetshuffle.com/index.php/wp-json/wp/v2/users/1"}], "replies": [{"embeddable": true, "href": "https://estreetshuffle.com/index.php/wp-json/wp/v2/comments?post=68336"}], "version-history": [{"count": 1, "href": "https://estreetshuffle.com/index.php/wp-json/wp/v2/posts/68336/revisions"}], "predecessor-version": [{"id": 68339, "href": "https://estreetshuffle.com/index.php/wp-json/wp/v2/posts/68336/revisions/68339"}], "wp:attachment": [{"href": "https://estreetshuffle.com/index.php/wp-json/wp/v2/media?parent=68336"}], "wp:term": [{"taxonomy": "category", "embeddable": true, "href": "https://estreetshuffle.com/index.php/wp-json/wp/v2/categories?post=68336"}, {"taxonomy": "post_tag", "embeddable": true, "href": "https://estreetshuffle.com/index.php/wp-json/wp/v2/tags?post=68336"}], "curies": [{"name": "wp", "href": "https://api.w.org/{rel}", "templated": true}]}}