/"}, "img": {"alt_text": "", "src": "https://i0.wp.com/estreetshuffle.com/wp-content/uploads/2019/08/1984-08-05.jpg?fit=1200%2C1200&ssl=1&resize=350%2C200", "width": 350, "height": 200, "srcset": "https://i0.wp.com/estreetshuffle.com/wp-content/uploads/2019/08/1984-08-05.jpg?fit=1200%2C1200&ssl=1&resize=350%2C200 1x, https://i0.wp.com/estreetshuffle.com/wp-content/uploads/2019/08/1984-08-05.jpg?fit=1200%2C1200&ssl=1&resize=525%2C300 1.5x, https://i0.wp.com/estreetshuffle.com/wp-content/uploads/2019/08/1984-08-05.jpg?fit=1200%2C1200&ssl=1&resize=700%2C400 2x, https://i0.wp.com/estreetshuffle.com/wp-content/uploads/2019/08/1984-08-05.jpg?fit=1200%2C1200&ssl=1&resize=1050%2C600 3x"}, "classes": []}, {"id": 57927, "url": "https://estreetshuffle.com/index.php/2025/08/07/kingdom-of-days-august-7-2/", "url_meta": {"origin": 57909, "position": 2}, "title": "August 7", "author": "Ken", "date": "August 7, 2025", "format": false, "excerpt": "Bruce kicks off the Rising Tour, plays the first \"Don't Look Back\" in 22 years, debuts a work-in-progress \"On the Prowl,\" and more.", "rel": "", "context": "In &quot;Kingdom of Days&quot;", "block_context": {"text": "Kingdom of Days", "link": "https://estreetshuffle.com/index.php/category/kingdom-of-days/"}, "img": {"alt_text": "", "src": "https://i0.wp.com/estreetshuffle.com/wp-content/uploads/2019/08/20020807_8_front.jpg?fit=952%2C945&ssl=1&resize=350%2C200", "width": 350, "height": 200, "srcset": "https://i0.wp.com/estreetshuffle.com/wp-content/uploads/2019/08/20020807_8_front.jpg?fit=952%2C945&ssl=1&resize=350%2C200 1x, https://i0.wp.com/estreetshuffle.com/wp-content/uploads/2019/08/20020807_8_front.jpg?fit=952%2C945&ssl=1&resize=525%2C300 1.5x, https://i0.wp.com/estreetshuffle.com/wp-content/uploads/2019/08/20020807_8_front.jpg?fit=952%2C945&ssl=1&resize=700%2C400 2x"}, "classes": []}, {"id": 56369, "url": "https://estreetshuffle.com/index.php/2025/04/05/kingdom-of-days-april-5-2/", "url_meta": {"origin": 57909, "position": 3}, "t