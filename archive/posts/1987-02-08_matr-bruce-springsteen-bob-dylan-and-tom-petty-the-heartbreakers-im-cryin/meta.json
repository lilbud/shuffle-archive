=350%2C200 1x, https://i0.wp.com/estreetshuffle.com/wp-content/uploads/2019/12/what-you-get.jpg?fit=1000%2C1000&ssl=1&resize=525%2C300 1.5x, https://i0.wp.com/estreetshuffle.com/wp-content/uploads/2019/12/what-you-get.jpg?fit=1000%2C1000&ssl=1&resize=700%2C400 2x"}, "classes": []}, {"id": 14436, "url": "https://estreetshuffle.com/index.php/1987/03/13/matr-bruce-springsteen-and-beaver-brown-money-thats-what-i-want/", "url_meta": {"origin": 25004, "position": 2}, "title": "Money (That&#8217;s What I Want)", "author": "Ken", "date": "March 13, 1987", "format": false, "excerpt": "Bruce Springsteen has covered Motown's first big hit several times over the years, but only two club performances from the eighties were caught on tape. Take a listen to both inside.", "rel": "", "context": "In &quot;Cover Me&quot;", "block_context": {"text": "Cover Me", "link": "https://estreetshuffle.com/index.php/category/cover-me/"}, "img": {"alt_text": "", "src": "https://i0.wp.com/estreetshuffle.com/wp-content/uploads/2019/11/admin-ajax-2026-06-09T170231.767.jpg?fit=1000%2C1000&ssl=1&resize=350%2C200", "width": 350, "height": 200, "srcset": "https://i0.wp.com/estreetshuffle.com/wp-content/uploads/2019/11/admin-ajax-2026-06-09T170231.767.jpg?fit=1000%2C1000&ssl=1&resize=350%2C200 1x, https://i0.wp.com/estreetshuffle.com/wp-content/uploads/2019/11/admin-ajax-2026-06-09T170231.767.jpg?fit=1000%2C1000&ssl=1&resize=525%2C300 1.5x, https://i0.wp.com/estreetshuffle.com/wp-content/uploads/2019/11/admin-ajax-2026-06-09T170231.767.jpg?fit=1000%2C1000&ssl=1&resize=700%2C400 2x"}, "classes": []}, {"id": 29805, "url": "https://estreetshuffle.com/index.php/2021/11/23/cover-me-its-my-life/", "url_meta": {"origin": 25004, "position": 3}, "title": "Cover Me: It&#8217;s My Life", "author": "Ken", "date": "November 23, 2021", "format": false, "excerpt": "Years before Darkness on the Edge of Town, Bruce gave his fans a glimpse at his dark side with his stunning cover of The Animals' \"It's My Life.\"", "rel"