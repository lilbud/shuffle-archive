050%2C600 3x"}, "classes": []}, {"id": 7533, "url": "https://estreetshuffle.com/index.php/2019/02/19/cover-me-purple-haze/", "url_meta": {"origin": 25004, "position": 5}, "title": "Cover Me: Purple Haze", "author": "Ken", "date": "February 19, 2019", "format": false, "excerpt": "Less than three months after it exploded onto the American rock scene, Bruce's high school band opened their show with a passionate cover of Jimi Hendrix's \"Purple Haze.\" Listen to a 17-year-old Bruce Springsteen tear it up inside.", "rel": "", "context": "In &quot;Cover Me&quot;", "block_context": {"text": "Cover Me", "link": "https://estreetshuffle.com/index.php/category/cover-me/"}, "img": {"alt_text": "", "src": "https://i0.wp.com/estreetshuffle.com/wp-content/uploads/2019/02/PurpleHazeUK.jpg?fit=500%2C494&ssl=1&resize=350%2C200", "width": 350, "height": 200}, "classes": []}], "_links": {"self": [{"href": "https://estreetshuffle.com/index.php/wp-json/wp/v2/posts/25004", "targetHints": {"allow": ["GET"]}}], "collection": [{"href": "https://estreetshuffle.com/index.php/wp-json/wp/v2/posts"}], "about": [{"href": "https://estreetshuffle.com/index.php/wp-json/wp/v2/types/post"}], "author": [{"embeddable": true, "href": "https://estreetshuffle.com/index.php/wp-json/wp/v2/users/1"}], "replies": [{"embeddable": true, "href": "https://estreetshuffle.com/index.php/wp-json/wp/v2/comments?post=25004"}], "version-history": [{"count": 10, "href": "https://estreetshuffle.com/index.php/wp-json/wp/v2/posts/25004/revisions"}], "predecessor-version": [{"id": 69742, "href": "https://estreetshuffle.com/index.php/wp-json/wp/v2/posts/25004/revisions/69742"}], "wp:featuredmedia": [{"embeddable": true, "href": "https://estreetshuffle.com/index.php/wp-json/wp/v2/media/69741"}], "wp:attachment": [{"href": "https://estreetshuffle.com/index.php/wp-json/wp/v2/media?parent=25004"}], "wp:term": [{"taxonomy": "category", "embeddable": true, "href": "https://estreetshuffle.com/index.php/wp-json/wp/v2/categories?post=25