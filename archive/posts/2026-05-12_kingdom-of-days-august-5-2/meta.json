2C443&amp;ssl=1 1024w, https://i0.wp.com/estreetshuffle.com/wp-content/uploads/2020/07/1984-08-05b.png?resize=768%2C332&amp;ssl=1 768w, https://i0.wp.com/estreetshuffle.com/wp-content/uploads/2020/07/1984-08-05b.png?resize=1536%2C664&amp;ssl=1 1536w, https://i0.wp.com/estreetshuffle.com/wp-content/uploads/2020/07/1984-08-05b.png?resize=2048%2C886&amp;ssl=1 2048w\" sizes=\"auto, (max-width: 758px) 100vw, 758px\" /></p>\n<p><img data-recalc-dims=\"1\" loading=\"lazy\" decoding=\"async\" data-attachment-id=\"20167\" data-permalink=\"https://estreetshuffle.com/1984-08-05c/\" data-orig-file=\"https://i0.wp.com/estreetshuffle.com/wp-content/uploads/2020/07/1984-08-05c.png?fit=1324%2C1030&amp;ssl=1\" data-orig-size=\"1324,1030\" data-comments-opened=\"1\" data-image-meta=\"{&quot;aperture&quot;:&quot;0&quot;,&quot;credit&quot;:&quot;&quot;,&quot;camera&quot;:&quot;&quot;,&quot;caption&quot;:&quot;&quot;,&quot;created_timestamp&quot;:&quot;0&quot;,&quot;copyright&quot;:&quot;&quot;,&quot;focal_length&quot;:&quot;0&quot;,&quot;iso&quot;:&quot;0&quot;,&quot;shutter_speed&quot;:&quot;0&quot;,&quot;title&quot;:&quot;&quot;,&quot;orientation&quot;:&quot;0&quot;}\" data-image-title=\"1984-08-05c\" data-image-description=\"\" data-image-caption=\"\" data-large-file=\"https://i0.wp.com/estreetshuffle.com/wp-content/uploads/2020/07/1984-08-05c.png?fit=758%2C590&amp;ssl=1\" class=\"alignnone wp-image-20167 size-full\" src=\"https://i0.wp.com/estreetshuffle.com/wp-content/uploads/2020/07/1984-08-05c.png?resize=758%2C590&#038;ssl=1\" alt=\"\" width=\"758\" height=\"590\" srcset=\"https://i0.wp.com/estreetshuffle.com/wp-content/uploads/2020/07/1984-08-05c.png?w=1324&amp;ssl=1 1324w, https://i0.wp.com/estreetshuffle.com/wp-content/uploads/2020/07/1984-08-05c.png?resize=300%2C233&amp;ssl=1 300w, https://i0.wp.com/estreetshuffle.com/wp-content/uploads/2020/07/1984-08-05c.png?resize=1024%2C797&amp;ssl=1 1024w, https://i0.wp.com/estreetshuffle.com/wp-content/uploads/2020/07/1984-08-05c.png?resize=768%2C597&amp;ssl=1 768w\" sizes=\"auto, (max-width: 758px) 100vw, 758px\" /></p>\n<p><strong>1985:\u00a0</strong>Bruce and the E Street Band kick off the final leg of the Born in the U.S.A. Tour&#8211;his first all-stadium tour&#8211;at RFK Stadium in Washington, DC. This show is notable for the second of only three performances ever of &#8220;Man at the Top,&#8221; the first U.S. performance of &#8220;Seeds,&#8221; and the first time Bruce closes a show with &#8220;Sherry Darling.&#8221;</p>\n<div class=\"jetpack-video-wrapper\"><span class=\"embed-youtube\" style=\"text-align:center; display: block;\"><iframe loading=\"lazy\" class=\"youtube-player\" width=\"758\" height=\"427\" src=\"https://www.youtube.com/embed/rm49wginqwo?version=3&#038;rel=1&#038;showsearch=0&#038;showinfo=1&#038;iv_load_policy=1&#038;fs=1&#038;hl=en-US&#038;autohide=2&#038;wmode=transparent\" allowfullscreen=\"true\" style=\"border:0;\" sandbox=\"allow-scripts allow-same-origin allow-popups allow-presentation allow-popups-to-escape-sandbox\"></iframe></span></div>\n<div class=\"jetpack-video-wrapper\"><span class=\"embed-youtube\" style=\"text-align:center; display: block;\"><iframe loading=\"lazy\" class=\"youtube-player\" width=\"758\" height=\"427\" src=\"https://www.youtube.com/embed?version=3&#038;rel=1&#038;showsearch=0&#038;showinfo=1&#038;iv_load_policy=1&#038;fs=1&#038;hl=en-US&#038;autohide=2&#038;wmode=transparent&#038;listType=playlist&#038;list=PLJTyL9twk3zAXbmVg0HYXLrk7xUqMNmCE\" allowfullscreen=\"true\" style=\"border:0;\" sandbox=\"allow-scripts allow-same-origin allow-popups allow-presentation allow-popups-to-escape-sandbox\"></iframe></span></div>\n<p>Because this show marks Bruce&#8217;s return to the U.S. and the first time playing to stadiums only, the kick-off show draws a lot of media attention. Watch the news coverage (a lot of it!) below.</p>\n<div class=\"jetpack-video-wrapper\"><span class=\"embed-youtube\" style=\"text-align:center; display: block;\"><iframe loading=\"lazy\" class=\"youtube-player\" width=\"758\" height=\"427\" src=\"https://www.youtube.com/embed/n54Xk96HALs?version=3&#038;rel=1&#038;showsearch=0&#038;showinfo=1&#038;iv_load_policy=1&#038;fs=1&#038;hl=en-US&#038;autohide=2&#038;wmode=transparent\" allowfullscreen=\"true\" style=\"border:0;\" sandbox=\"allow-scripts allow-same-origin allow-popups allow-presentation allow-popups-to-escape-sandbox\"></iframe></span></div>\n<p><img data-recalc-dims=\"1\" loading=\"lazy\" decoding=\"async\" data-attachment-id=\"20168\" data-permalink=\"https://estreetshuffle.com/1985-08-05a/\" data-orig-file=\"https://i0.wp.com/estreetshuffle.com/wp-content/uploads/2020/07/1985-08-05a.png?fit=1491%2C1748&amp;ssl=1\" data-orig-size=\"1491,1748\" data-comments-opened=\"1\" data-image-meta=\"{&quot;aperture&quot;:&quot;0&quot;,&quot;credit&quot;:&quot;&quot;,&quot;camera&quot;:&quot;&quot;,&quot;caption&quot;:&quot;&quot;,&quot;created_timestamp&quot;:&quot;0&quot;,&quot;copyright&quot;:&quot;&quot;,&quot;focal_length&quot;:&quot;0&quot;,&quot;iso&quot;:&quot;0&quot;,&quot;shutter_speed&quot;:&quot;0&quot;,&quot;title&quot;:&quot;&quot;,&quot;orientation&quot;:&quot;0&quot;}\" data-image-title=\"1985-08-05a\" data-image-description=\"\" data-image-caption=\"\" data-large-file=\"https://i0.wp.com/estreetshuffle.com/wp-content/uploads/2020/07/1985-08-05a.png?fit=758%2C889&amp;ssl=1\" class=\"alignnone wp-image-20168 size-full\" src=\"https://i0.wp.com/estreetshuffle.com/wp-content/uploads/2020/07/1985-08-05a.png?resize=758%2C889&#038;ssl=1\" alt=\"\" width=\"758\" height=\"889\" srcset=\"https://i0.wp.com/estreetshuffle.com/wp-content/uploads/2020/07/1985-08-05a.png?w=1491&amp;ssl=1 1491w, https://i0.wp.com/estreetshuffle.com/wp-content/uploads/2020/07/1985-08-05a.png?resize=256%2C300&amp;ssl=1 256w, https://i0.wp.com/estreetshuffle.com/wp-content/uploads/2020/07/1985-08-05a.png?resize=873%2C1024&amp;ssl=1 873w, https://i0.wp.com/estreetshuffle.com/wp-content/uploads/2020/07/19