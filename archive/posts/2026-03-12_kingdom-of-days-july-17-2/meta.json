ley.jpg?fit=1024%2C1024&ssl=1&resize=700%2C400 2x"}, "classes": []}, {"id": 57911, "url": "https://estreetshuffle.com/index.php/2025/08/06/kingdom-of-days-august-6-2/", "url_meta": {"origin": 57748, "position": 5}, "title": "Kingdom of Days: August 6", "author": "Ken", "date": "August 6, 2025", "format": false, "excerpt": "Bruce finishes \"Born to Run,\" says farewell to Jon Stewart on The Daily Show, shoots the video for \"Leap of Faith\" and records official live performances of \"Nebraska,\" \"No Surrender,\" and \"Trapped.\" Lots of video and audio today.", "rel": "", "context": "In &quot;Kingdom of Days&quot;", "block_context": {"text": "Kingdom of Days", "link": "https://estreetshuffle.com/index.php/category/kingdom-of-days/"}, "img": {"alt_text": "", "src": "https://i0.wp.com/estreetshuffle.com/wp-content/uploads/2021/08/1984-08-06-east-rutherford-nj.jpg?fit=640%2C640&ssl=1&resize=350%2C200", "width": 350, "height": 200, "srcset": "https://i0.wp.com/estreetshuffle.com/wp-content/uploads/2021/08/1984-08-06-east-rutherford-nj.jpg?fit=640%2C640&ssl=1&resize=350%2C200 1x, https://i0.wp.com/estreetshuffle.com/wp-content/uploads/2021/08/1984-08-06-east-rutherford-nj.jpg?fit=640%2C640&ssl=1&resize=525%2C300 1.5x"}, "classes": []}], "_links": {"self": [{"href": "https://estreetshuffle.com/index.php/wp-json/wp/v2/posts/57748", "targetHints": {"allow": ["GET"]}}], "collection": [{"href": "https://estreetshuffle.com/index.php/wp-json/wp/v2/posts"}], "about": [{"href": "https://estreetshuffle.com/index.php/wp-json/wp/v2/types/post"}], "author": [{"embeddable": true, "href": "https://estreetshuffle.com/index.php/wp-json/wp/v2/users/1"}], "replies": [{"embeddable": true, "href": "https://estreetshuffle.com/index.php/wp-json/wp/v2/comments?post=57748"}], "version-history": [{"count": 5, "href": "https://estreetshuffle.com/index.php/wp-json/wp/v2/posts/57748/revisions"}], "predecessor-version": [{"id": 68261, "href": "https://estreetshuffle.com/index.php/wp-json/wp/v2/posts/