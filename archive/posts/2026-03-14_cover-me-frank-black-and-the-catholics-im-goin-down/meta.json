=1200%2C675&ssl=1&resize=1050%2C600 3x"}, "classes": []}, {"id": 17352, "url": "https://estreetshuffle.com/index.php/2020/04/12/cover-me-free-redemption-im-goin-down/", "url_meta": {"origin": 27775, "position": 2}, "title": "Cover Me, Free Redemption: I&#8217;m Goin&#8217; Down", "author": "Ken", "date": "April 12, 2020", "format": false, "excerpt": "Free Redemption is a new band out of Italy, and to call them a tribute band would be a vast disservice. Their mission is to reinterpret Bruce's music, and they hit it out of the park with \"I'm Goin' Down.\"", "rel": "", "context": "In &quot;Cover Me&quot;", "block_context": {"text": "Cover Me", "link": "https://estreetshuffle.com/index.php/category/cover-me/"}, "img": {"alt_text": "", "src": "https://i0.wp.com/estreetshuffle.com/wp-content/uploads/2020/04/freeredeem.png?fit=960%2C720&ssl=1&resize=350%2C200", "width": 350, "height": 200, "srcset": "https://i0.wp.com/estreetshuffle.com/wp-content/uploads/2020/04/freeredeem.png?fit=960%2C720&ssl=1&resize=350%2C200 1x, https://i0.wp.com/estreetshuffle.com/wp-content/uploads/2020/04/freeredeem.png?fit=960%2C720&ssl=1&resize=525%2C300 1.5x, https://i0.wp.com/estreetshuffle.com/wp-content/uploads/2020/04/freeredeem.png?fit=960%2C720&ssl=1&resize=700%2C400 2x"}, "classes": []}, {"id": 3567, "url": "https://estreetshuffle.com/index.php/2018/08/01/cover-me-vampire-weekend-im-goin-down/", "url_meta": {"origin": 27775, "position": 3}, "title": "Cover Me, Vampire Weekend: I&#8217;m Goin&#8217; Down", "author": "Ken", "date": "August 1, 2018", "format": false, "excerpt": "Recorded live and professionally in Seattle, Vampire Weekend performs an acoustic cover of \"I'm Goin' Down.\"", "rel": "", "context": "In &quot;Cover Me&quot;", "block_context": {"text": "Cover Me", "link": "https://estreetshuffle.com/index.php/category/cover-me/"}, "img": {"alt_text": "", "src": "https://i0.wp.com/estreetshuffle.com/wp-content/uploads/2018/08/vampire-e1533054368772.jpg?fit=600%2C338&ssl=1&resize=